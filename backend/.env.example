# TargoBD Environment Variables
# এই file-এর নাম .env করুন এবং নিচের values পূরণ করুন

# MongoDB Connection (MongoDB Atlas থেকে নিন - free)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/targobd

# JWT Secret (যেকোনো random string দিন)
JWT_SECRET=targobd_super_secret_key_2026_change_this

# Server Port
PORT=5000

# Frontend URL (আপনার domain)
FRONTEND_URL=https://targobd.com

# Email (order notification এর জন্য - Gmail)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password

# Admin info (প্রথম admin account)
ADMIN_EMAIL=admin@targobd.com
ADMIN_PASSWORD=Admin@123456
